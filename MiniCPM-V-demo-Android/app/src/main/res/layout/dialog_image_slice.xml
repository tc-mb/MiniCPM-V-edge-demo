<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog body for the chat-page "max image slice" setting.
    Layout target: AlertDialog.Builder.setView(this).
    Wired in MainActivity#showImageSliceDialog().
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="0dp">

    <TextView
        android:id="@+id/tv_image_slice_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        tools:text="3" />

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_image_slice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:valueFrom="1"
        android:valueTo="9"
        android:stepSize="1"
        android:value="1"
        app:tickVisible="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="-4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/image_slice_label_min" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/image_slice_label_max" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:lineSpacingExtra="2dp"
        android:text="@string/image_slice_hint" />
</LinearLayout>
